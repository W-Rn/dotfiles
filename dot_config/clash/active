#!/bin/bash

# ================= 配置区 =================
CLASH_DIR="$HOME/.config/clash"
CLASH_BIN="$CLASH_DIR/clash"
CONFIG_FILE="$CLASH_DIR/config.yaml"
LOG_FILE="$CLASH_DIR/clash.log"
PROXY_PORT="7897"
PROXY_URL="http://127.0.0.1:$PROXY_PORT"
SSH_CONFIG="$HOME/.ssh/config"
# ==========================================

# 1. 确保环境就绪
# mkdir -p "$HOME/.ssh"
if [ ! -f "$SSH_CONFIG" ]; then
    echo "📄 创建新的 SSH 配置文件..."
    touch "$SSH_CONFIG"
    chmod 600 "$SSH_CONFIG"
fi
if ! command -v nc &>/dev/null; then
    echo "提示: 未检测到 nc，正在安装 netcat-openbsd..."
    sudo apt update && sudo apt install netcat-openbsd -y
fi

# 2. 启动 Clash 进程
if pgrep -f "$CLASH_BIN -f $CONFIG_FILE" >/dev/null; then
    echo "⚠️  Clash 已在运行中。"
    echo -e "\n🔄 正在验证连接..."
    if curl -I -s --connect-timeout 5 https://www.google.com | grep -q "HTTP/"; then
        echo "✅ 代理测试: 成功！(Google 可访问)"
    else
        echo "⚠️  代理测试: 失败 (请检查 Clash 配置或节点状态)"
    fi
    exit 1
else
    echo "🚀 正在启动 Clash 代理服务器..."
    nohup "$CLASH_BIN" -f "$CONFIG_FILE" >"$LOG_FILE" 2>&1 &
    sleep 2
    if pgrep -f "$CLASH_BIN -f $CONFIG_FILE" >/dev/null; then
        echo "✅ Clash 启动成功 (PID: $(pgrep -f "$CLASH_BIN -f $CONFIG_FILE"))"
    else
        echo "❌ Clash 启动失败，请查看日志: $LOG_FILE"
        exit 1
    fi
fi

# 3. 设置终端环境变量 (针对 curl/wget)
export http_proxy="$PROXY_URL"
export https_proxy="$PROXY_URL"
export HTTP_PROXY="$PROXY_URL"
export HTTPS_PROXY="$PROXY_URL"
echo "🌐 终端环境变量已注入 ($PROXY_URL)"

# 4. 配置 Git HTTP 代理
git config --global http.proxy "$PROXY_URL"
git config --global https.proxy "$PROXY_URL"
echo "📦 Git HTTP 代理已配置"

# 5. 配置 SSH ProxyCommand (针对 git@github.com)
if ! grep -q "Host github.com" "$SSH_CONFIG"; then
    cat >>"$SSH_CONFIG" <<EOF

Host github.com
    HostName github.com
    User git
    ProxyCommand nc -X connect -x 127.0.0.1:$PROXY_PORT %h %p
    ServerAliveInterval 60
EOF
    echo "🔑 SSH Config 已添加 GitHub 代理规则"
else
    echo "ℹ️  SSH Config 已存在 GitHub 规则，跳过修改"
fi
chmod 600 "$SSH_CONFIG"

# 6. 配置 Apt 代理 (需 sudo)
echo "💉 正在配置 Apt 系统代理..."
sudo bash -c "cat > /etc/apt/apt.conf.d/99proxy << EOF
Acquire::http::Proxy \"$PROXY_URL/\";
Acquire::https::Proxy \"$PROXY_URL/\";
EOF"

# 7. 最终测试
echo -e "\n🔄 正在验证连接..."
if curl -I -s --connect-timeout 5 https://www.google.com | grep -q "HTTP/"; then
    echo "✅ 代理测试: 成功！(Google 可访问)"
else
    echo "⚠️  代理测试: 失败 (请检查 Clash 配置或节点状态)"
fi

echo -e "\n📝 代理操作指南:"
echo "• 终端环境: 当前窗口已注入代理变量"
echo "• 全局生效: Git/Apt/SSH 代理已写入配置 (持久生效)"
echo ""
echo "  💡 快捷指令 (Alias):"
echo "  🚀 开启/更新代理: clash_start  (当前已执行)"
echo "  🛑 关闭并清理:   clash_stop"
echo "  🔄 重启代理服务: clash_restart"
