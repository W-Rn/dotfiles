#!/bin/bash
SSH_CONFIG="$HOME/.ssh/config"

echo "🛑 正在关闭代理配置..."

# 1. 停止 Clash (加个判断，防止没启动时报错)
if pgrep -f "clash" >/dev/null; then
    pkill -f "clash"
    echo "✅ Clash 进程已关闭"
fi

# 2. 清除环境变量
unset http_proxy https_proxy HTTP_PROXY HTTPS_PROXY
echo "✅ 终端环境变量已清除"

# 3. 清除 Git 配置
git config --global --unset http.proxy
git config --global --unset https.proxy
echo "✅ Git 全局代理已取消"

# 4. 清除 Apt 配置
sudo rm -f /etc/apt/apt.conf.d/99proxy
echo "✅ Apt 系统代理已清理"

# 5. 精准清除 SSH Config
if [ -f "$SSH_CONFIG" ]; then
    # 使用 sed 删除 GitHub 代理块
    sed -i '/Host github.com/,/ServerAliveInterval 60/d' "$SSH_CONFIG"
    echo "✅ SSH GitHub 代理已移除 (保留了其他 SSH 配置)"
fi

echo -e "\n✨ 所有代理配置已清理，网络恢复直连。"
